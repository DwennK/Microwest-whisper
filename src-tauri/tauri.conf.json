{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Microwest Whisper",
  "version": "0.2.0",
  "identifier": "com.iaswiss.microwestwhisper",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run prepare:whispercpp && npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Microwest Whisper",
        "width": 1280,
        "height": 860,
        "minWidth": 1000,
        "minHeight": 720,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/engine/whispercpp/": "engine/whispercpp"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkzMjE1NzM2NkVFNEIwRTUKUldUbHNPUnVObGNoazZ1b1BlczRNZXZMSVFBTnQ0WVc4eHNjTTA4anhPeUdJdHN2OFZxbk51MlAK",
      "endpoints": [
        "https://github.com/DwennK/Microwest-whisper/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
